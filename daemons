#!/bin/bash
# daemons - observe the homegrown launchd daemons: write/read per-daemon activity logs
#
# Usage:
#   daemons append <name> <event> [detail|--detail-stdin]   Append one activity record
#   daemons status                           Summarize all daemons (loaded? last activity + counts)
#   daemons check                            Health+activity gate (returns nonzero on problem)
#   daemons log [name|--all] [-f|--follow]   Render the log (human-readable)
#   daemons query [name|--all] [options]     Filter/extract JSONL records
#   daemons -h | --help
#
# Environment:
#   DAEMONS_LOG_DIR   Directory of <name>.log files (default: $XDG_STATE_HOME/daemons or ~/.local/state/daemons)
#   DAEMONS_REGISTRY  Registry TSV (default: $XDG_CONFIG_HOME/daemons/daemons.tsv or ~/.config/daemons/daemons.tsv)

PATH="/opt/homebrew/bin:/usr/local/bin:$PATH" # LaunchDaemons get a minimal PATH; need jq

_daemons() (
    local SCRIPT_NAME; SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"
    case "${BASH_SOURCE[0]}" in /dev/*|/proc/*) SCRIPT_NAME="" ;; esac
    case "$SCRIPT_NAME" in ""|bash|sh|zsh|dash) SCRIPT_NAME="daemons" ;; esac

    local LOG_DIR="${DAEMONS_LOG_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/daemons}"
    local REGISTRY="${DAEMONS_REGISTRY:-${XDG_CONFIG_HOME:-$HOME/.config}/daemons/daemons.tsv}"

    _error() { echo "[ERR][$SCRIPT_NAME] $*" >&2; }

    _show_help() {
        local s; [ -t 1 ] && s=$'\033[4m'
        local r; [ -t 1 ] && r=$'\033[24m'
        cat <<EOF
NAME
  $SCRIPT_NAME - observe the homegrown launchd daemons
SYNOPSIS
  $SCRIPT_NAME append <${s}name${r}> <${s}event${r}> [${s}detail${r}|--detail-stdin]
  $SCRIPT_NAME status
  $SCRIPT_NAME check
  $SCRIPT_NAME log [${s}name${r}|--all] [-f|--follow]
  $SCRIPT_NAME query [${s}name${r}|--all] [--event ${s}E${r}] [--since ${s}T${r}] [--jq ${s}EXPR${r}]
DESCRIPTION
  Writes and reads per-daemon activity logs (JSONL) under \$DAEMONS_LOG_DIR.
  Each record is {ts, daemon, event, detail}; event is trigger|noop|change|error.
  'append' is the write path daemons call; 'status'/'check'/'log'/'query' read.
SUBCOMMANDS
  append   Append one activity record (creates the log dir on first write). Pass --detail-stdin in place of [detail] to read the detail from stdin
  status   Per-daemon summary: loaded? + last activity (event + timestamp) + all-time event counts; "never fired" when no log
  check    Health+activity gate; nonzero + loud alerts on any problem
  log      Render the log human-readably (--all merges; -f/--follow follows)
  query    Filter/extract JSONL by --event/--since/--all/--jq
           --since accepts NNN[smh] (e.g. 1h, 30m), a bare date YYYY-MM-DD (midnight UTC), or a full ISO-8601 UTC timestamp
ENVIRONMENT
  DAEMONS_LOG_DIR   Directory of <name>.log files (default: \$XDG_STATE_HOME/daemons or ~/.local/state/daemons)
  DAEMONS_REGISTRY  Registry TSV (default: \$XDG_CONFIG_HOME/daemons/daemons.tsv or ~/.config/daemons/daemons.tsv)
FILES
  \$DAEMONS_REGISTRY  Whitespace-separated table that 'status' and 'check' read
                     (append/log/query don't need it). A header row, then one
                     row per daemon with four columns:
                       name    log name; matches the <name> passed to append
                       domain  launchd domain: gui/\$UID/ (per-user agent; \$UID
                               is replaced with your numeric uid) or system/
                       label   launchd label; state read via launchctl print <domain><label>
                       script  path to the daemon's script; check flags it if missing
                     Example:
                       name       domain     label                  script
                       reconcile  gui/\$UID/  com.example.reconcile  /usr/local/bin/reconcile
DEPENDENCIES
  jq, launchctl
EXIT STATUS
  0  Success
  1  Runtime failure
  2  Usage error (unknown/missing subcommand or option)
  3  jq not installed
EOF
    }

    _do_append() {
        local name="${1:-}"
        local event="${2:-}"
        if [ -z "$name" ] || [ -z "$event" ]; then
            _error "append requires <name> and <event>. Run \`$SCRIPT_NAME -h\` for usage"
            return 2
        fi
        case "$event" in
            trigger|noop|change|error) ;;
            *) _error "Invalid event '$event' (valid: trigger|noop|change|error). Run \`$SCRIPT_NAME -h\` for usage"; return 2 ;;
        esac
        local detail
        if [ "${3:-}" = "--detail-stdin" ]; then
            detail="$(cat)"
        else
            detail="${3:-}"
        fi
        local ts; ts="$(TZ=Etc/UTC date '+%Y-%m-%dT%H:%M:%SZ')"
        mkdir -p "$LOG_DIR" || { _error "cannot create $LOG_DIR"; return 1; }
        # --rawfile reads raw detail (any bytes) into a JSON string; --arg for the rest
        jq -cn --arg ts "$ts" --arg daemon "$name" --arg event "$event" \
            --rawfile detail <(printf '%s' "$detail") \
            '{ts:$ts, daemon:$daemon, event:$event, detail:($detail)}' \
            >> "$LOG_DIR/$name.log" || { _error "failed to write log record"; return 1; }
    }

    # Echo the log file path(s) for a name, or all logs for --all. No error if absent
    _log_files_for() {
        local target="${1:-}"
        if [ "$target" = "--all" ] || [ -z "$target" ]; then
            # All *.log in LOG_DIR (may be none)
            local f
            for f in "$LOG_DIR"/*.log; do [ -e "$f" ] && printf '%s\n' "$f"; done
        else
            [ -e "$LOG_DIR/$target.log" ] && printf '%s\n' "$LOG_DIR/$target.log"
        fi
    }

    # Normalize --since: a bare date (YYYY-MM-DD) becomes midnight UTC; an ISO
    # timestamp passes through; NNN[smh] becomes "now minus that span"
    _since_to_ts() {
        local t="$1"
        case "$t" in
            [0-9]*[smh])
                local n="${t%[smh]}"; local unit="${t##*[0-9]}"
                local secs=0
                case "$unit" in s) secs=$n ;; m) secs=$((n*60)) ;; h) secs=$((n*3600)) ;; esac
                TZ=Etc/UTC date -v-"${secs}"S '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null \
                    || TZ=Etc/UTC date -u -d "-${secs} seconds" '+%Y-%m-%dT%H:%M:%SZ' ;;
            ????-??-??) printf '%sT00:00:00Z\n' "$t" ;;
            *) printf '%s\n' "$t" ;;
        esac
    }

    _do_query() {
        local target=""
        local event=""
        local since=""
        local jqexpr="."
        while [ $# -gt 0 ]; do
            case "$1" in
                --all) target="--all"; shift ;;
                --event) [ $# -ge 2 ] || { _error "--event requires a value. Run \`$SCRIPT_NAME -h\` for usage"; return 2; }; event="$2"; shift 2 ;;
                --event=*) event="${1#*=}"; shift ;;
                --since) [ $# -ge 2 ] || { _error "--since requires a value. Run \`$SCRIPT_NAME -h\` for usage"; return 2; }; since="$2"; shift 2 ;;
                --since=*) since="${1#*=}"; shift ;;
                --jq) [ $# -ge 2 ] || { _error "--jq requires a value. Run \`$SCRIPT_NAME -h\` for usage"; return 2; }; jqexpr="$2"; shift 2 ;;
                --jq=*) jqexpr="${1#*=}"; [ -n "$jqexpr" ] || { _error "--jq requires a value. Run \`$SCRIPT_NAME -h\` for usage"; return 2; }; shift ;;
                -*) _error "Unknown argument '$1'. Run \`$SCRIPT_NAME -h\` for usage"; return 2 ;;
                *) target="$1"; shift ;;
            esac
        done
        local since_ts=""
        [ -n "$since" ] && since_ts="$(_since_to_ts "$since")"
        local files; files="$(_log_files_for "$target")"
        [ -z "$files" ] && return 0
        # Filter each record: event match (if set), ts >= since (if set), then apply jqexpr
        printf '%s\n' "$files" | while IFS= read -r f; do
            [ -n "$f" ] || continue
            jq -c \
                --arg event "$event" --arg since "$since_ts" \
                'select(($event=="" or .event==$event) and ($since=="" or .ts>=$since))' "$f"
        done | { [ "$jqexpr" = "." ] && cat || jq "$jqexpr"; }
    }

    # Render JSONL from stdin: one header line per record + indented extra detail lines
    _render_records() {
        jq -r '
            "\(.ts) \(.daemon) \(.event|ascii_upcase) \(.detail | split("\n")[0] // "")",
            (.detail | split("\n")[1:][] | "  " + .)
        '
    }

    # Echo registry rows as name<TAB>domain<TAB>label<TAB>script. Skips the header
    # row and blank lines. Errors (return 1) if the registry file is absent
    _read_registry() {
        if [ ! -f "$REGISTRY" ]; then
            _error "registry not found: $REGISTRY"
            return 1
        fi
        # Skip header (first line) and blanks; collapse runs of whitespace/tabs to a single tab
        local uid; uid="$(id -u)"
        tail -n +2 "$REGISTRY" | while IFS= read -r row; do
            [ -n "$row" ] || continue
            # Split on whitespace runs into 4 fields (script path assumed space-free)
            local name
            local domain
            local label
            local script
            read -r name domain label script <<< "$row"
            [ -n "$name" ] || continue
            # Substitute $UID token in the domain
            domain="${domain//\$UID/$uid}"
            printf '%s\t%s\t%s\t%s\n' "$name" "$domain" "$label" "$script"
        done
    }

    # Echo `launchctl print <domain><label>` text; return nonzero if not loaded
    _launchd_state() {
        launchctl print "$1$2" 2>/dev/null
    }

    _do_status() {
        local rows; rows="$(_read_registry)" || return 1
        printf '%s\n' "$rows" | while IFS=$'\t' read -r name domain label script; do
            [ -n "$name" ] || continue
            local loaded="loaded"
            _launchd_state "$domain" "$label" >/dev/null || loaded="NOT LOADED"
            local logf="$LOG_DIR/$name.log"
            local activity
            if [ ! -e "$logf" ]; then
                activity="never fired"
            else
                local last_ts; last_ts="$(jq -rs 'last | .ts // "?"' "$logf" 2>/dev/null)"
                local last_ev; last_ev="$(jq -rs 'last | .event // "?"' "$logf" 2>/dev/null)"
                # Counts by event (all-time; simple and enough for a glance)
                local n_change; n_change="$(jq -rs '[.[]|select(.event=="change")]|length' "$logf" 2>/dev/null)"
                local n_noop; n_noop="$(jq -rs '[.[]|select(.event=="noop")]|length' "$logf" 2>/dev/null)"
                local n_err; n_err="$(jq -rs '[.[]|select(.event=="error")]|length' "$logf" 2>/dev/null)"
                activity="last $last_ev @ $last_ts ($n_change change, $n_noop noop, $n_err error)"
            fi
            printf '%-24s %-11s %s\n' "$name" "$loaded" "$activity"
        done
    }

    # Loud alert line (bold + red), to stdout so the login shell shows it inline
    _alert() {
        local b; local red; local rst
        if [ -t 1 ]; then b=$'\033[1m'; red=$'\033[31m'; rst=$'\033[0m'; fi
        printf '%s%s[daemons] %s%s\n' "$b" "$red" "$*" "$rst"
    }

    _do_check() {
        local rows; rows="$(_read_registry)" || return 1
        local problems=0
        # Use a temp file for the problem count: the while loop runs in a subshell
        # (piped), so a plain variable increment wouldn't survive. Portable to bash 3.2
        local flag; flag="$(mktemp)"
        printf '0' > "$flag"
        printf '%s\n' "$rows" | while IFS=$'\t' read -r name domain label script; do
            [ -n "$name" ] || continue
            local state
            if ! state="$(_launchd_state "$domain" "$label")"; then
                _alert "$label not loaded in launchd!"
                printf '1' > "$flag"; continue
            fi
            if [ -n "$script" ] && [ ! -f "$script" ]; then
                _alert "$label points at a missing script ($script) -- re-run its install"
                printf '1' > "$flag"; continue
            fi
            # launchd prints "last exit code = (never exited)" for a loaded
            # service that has not run yet this boot (every WatchPaths daemon,
            # right after a restart, before its trigger first fires) -- that is
            # not a failure. Read the value after "= " (not $NF, which would
            # pluck "exited)" off "(never exited)") and alert only on a non-zero
            # integer exit code (codes are 0-255, always digits); a non-numeric
            # value like "(never exited)" means no run recorded, so skip it
            local last_exit; last_exit="$(printf '%s\n' "$state" | awk -F' = ' '/last exit code/ {print $2; exit}')"
            case "$last_exit" in
                ''|0) ;; # no code recorded, or a clean exit
                *[!0-9]*) ;; # non-numeric (e.g. "(never exited)") -- not a failure
                *) _alert "$label last run failed (exit $last_exit)"; printf '1' > "$flag" ;;
            esac
        done
        problems="$(cat "$flag")"; rm -f "$flag"
        [ "$problems" = 0 ]
    }

    _do_log() {
        local follow=""
        local target=""
        while [ $# -gt 0 ]; do
            case "$1" in
                -f|--follow) follow=1; shift ;;
                --all) target="--all"; shift ;;
                -*) _error "Unknown argument '$1'. Run \`$SCRIPT_NAME -h\` for usage"; return 2 ;;
                *) target="$1"; shift ;;
            esac
        done
        local files; files="$(_log_files_for "$target")"
        [ -z "$files" ] && return 0
        if [ -n "$follow" ]; then
            # Follow: tail -f the file(s); render each incoming JSONL line
            # -q suppresses the "==> path <==" banners tail prints with 2+ files, which are not JSON and would abort the jq parse
            # shellcheck disable=SC2086 # "Double quote to prevent globbing and word splitting." -- $files is a newline list of paths we intentionally word-split into tail's args
            tail -f -q $files | _render_records
        else
            # Merge-sort all records by ts (line-sortable ISO-UTC), then render
            # shellcheck disable=SC2086 # "Double quote to prevent globbing and word splitting." -- $files is a newline list of paths we intentionally word-split into cat's args
            cat $files | jq -c . | sort | _render_records
        fi
    }

    if ! command -v jq >/dev/null 2>&1; then _error "jq is required"; return 3; fi

    local subcmd="${1:-}"
    [ $# -gt 0 ] && shift
    case "$subcmd" in
        -h|--help) _show_help; return 0 ;;
        "") _error "Must provide a subcommand. Run \`$SCRIPT_NAME -h\` for usage"; return 2 ;;
        append)  _do_append "$@"; return $? ;;
        status)  _do_status "$@"; return $? ;;
        check)   _do_check "$@"; return $? ;;
        log)     _do_log "$@"; return $? ;;
        query)   _do_query "$@"; return $? ;;
        *) _error "Unknown argument '$subcmd'. Run \`$SCRIPT_NAME -h\` for usage"; return 2 ;;
    esac
)

_daemons "$@"
__daemons_rc=$?
unset -f _daemons
if [ -n "${BASH_SOURCE[0]}" ] && [ "${BASH_SOURCE[0]}" != "$0" ]; then
    eval "unset __daemons_rc; return $__daemons_rc"
fi
eval "unset __daemons_rc; exit $__daemons_rc"
