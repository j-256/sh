#!/bin/bash
# spf - Resolve and inspect SPF DNS records
#
# Usage:
#   spf [options] find    <domain>           Find matching SPF mechanism for an IP
#   spf [options] flatten <domain>           Print all IPs authorized by an SPF record
#   spf [options] check   <domain>           Check SPF health (lookups, includes, etc.)
#   spf [options] tree    <domain>           Print SPF include tree
#   spf -h
#
# Options:
#   -s, --server <ip>   DNS server to query (default: 8.8.8.8)
#   -d, --domain <dom>  Restrict output to a specific domain anchor
#   --tcp               Force TCP instead of UDP for dig queries
#   -q, --quiet         Suppress informational output
#   -h, --help          Show help message

_spf() (
    local SCRIPT_NAME; SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"
    case "${BASH_SOURCE[0]}" in /dev/*|/proc/*) SCRIPT_NAME="" ;; esac
    case "$SCRIPT_NAME" in ""|bash|sh|zsh|dash) SCRIPT_NAME="spf" ;; esac

    _error() { echo "[ERR][$SCRIPT_NAME] $*" >&2; }

    _show_help() {
        local s; [ -t 1 ] && s=$'\033[4m'
        local r; [ -t 1 ] && r=$'\033[24m'
        echo "NAME"
        echo "  $SCRIPT_NAME - resolve and inspect SPF DNS records"
        echo "SYNOPSIS"
        echo "  $SCRIPT_NAME [${s}options${r}] find    ${s}domain${r}"
        echo "  $SCRIPT_NAME [${s}options${r}] flatten ${s}domain${r}"
        echo "  $SCRIPT_NAME [${s}options${r}] check   ${s}domain${r}"
        echo "  $SCRIPT_NAME [${s}options${r}] tree    ${s}domain${r}"
        echo "  $SCRIPT_NAME -h"
        echo "DESCRIPTION"
        echo "  Fetches and recursively resolves SPF TXT records for a domain."
        echo "  Four subcommands cover the common inspection tasks: find a"
        echo "  matching mechanism for an IP, flatten all authorized addresses,"
        echo "  check record health, and print the full include tree."
        echo "OPTIONS"
        echo "  -s, --server ${s}ip${r}   DNS server to query (default: 8.8.8.8)"
        echo "  -d, --domain ${s}dom${r}  Restrict output to a specific domain anchor"
        echo "  --tcp             Force TCP instead of UDP for dig queries"
        echo "  -q, --quiet       Suppress informational output"
        echo "  -h, --help        Show this help message"
        echo "DEPENDENCIES"
        echo "  dig"
        echo "  python3 (IPv6 matching only)"
        echo "EXIT STATUS"
        echo "  0  Success"
        echo "  1  Runtime failure (network error, dig returned unexpected output)"
        echo "  2  Usage error (missing arg, unknown flag, bad flag value)"
        echo "  3  dig is not installed"
        echo "  4  Negative predicate result (IP did not match any mechanism)"
    }

    _expand_short_opts() {
        # $1 = string of short-opt letters that take a value (e.g. "nXHd"); "" for flag-only scripts
        # $2..$N = "$@"
        # Populates _EXPANDED; caller does: set -- "${_EXPANDED[@]}"; unset _EXPANDED
        local value_opts="$1"; shift
        _EXPANDED=()
        local passthru=""
        local arg
        local rest
        local c
        for arg in "$@"; do
            if [ -n "$passthru" ]; then _EXPANDED+=("$arg"); continue; fi
            case "$arg" in
                --)          passthru=1; _EXPANDED+=("$arg") ;;
                --*|-|"")    _EXPANDED+=("$arg") ;;
                -[a-zA-Z]?*)
                    rest="${arg#-}"
                    while [ -n "$rest" ]; do
                        c="${rest%"${rest#?}"}"; rest="${rest#?}"
                        _EXPANDED+=("-$c")
                        case "$value_opts" in *"$c"*)
                            [ -n "$rest" ] && _EXPANDED+=("$rest")
                            rest="" ;;
                        esac
                    done ;;
                *)           _EXPANDED+=("$arg") ;;
            esac
        done
    }

    # --- command stubs (implemented in later tasks) ---

    _cmd_find()    { return 0; }
    _cmd_flatten() { return 0; }
    _cmd_check()   { return 0; }
    _cmd_tree()    { return 0; }

    # --- defaults and parse arguments ---
    local SERVER; SERVER="8.8.8.8"
    local DOMAIN_ANCHOR; DOMAIN_ANCHOR=""
    local USE_TCP; USE_TCP=""
    local QUIET; QUIET=""
    local -a args=()

    _expand_short_opts "sd" "$@"
    set -- "${_EXPANDED[@]}"; unset _EXPANDED

    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help) _show_help; return 0 ;;
            -s|--server)
                [ -n "${2-}" ] || { _error "--server requires a value. Run \`$SCRIPT_NAME -h\` for usage"; return 2; }
                SERVER="$2"; shift 2 ;;
            --server=*)
                SERVER="${1#*=}"
                [ -n "$SERVER" ] || { _error "--server requires a value. Run \`$SCRIPT_NAME -h\` for usage"; return 2; }
                shift ;;
            -d|--domain)
                [ -n "${2-}" ] || { _error "--domain requires a value. Run \`$SCRIPT_NAME -h\` for usage"; return 2; }
                DOMAIN_ANCHOR="$2"; shift 2 ;;
            --domain=*)
                DOMAIN_ANCHOR="${1#*=}"
                [ -n "$DOMAIN_ANCHOR" ] || { _error "--domain requires a value. Run \`$SCRIPT_NAME -h\` for usage"; return 2; }
                shift ;;
            --tcp) USE_TCP=1; shift ;;
            -q|--quiet) QUIET=1; shift ;;
            --) shift; while [ $# -gt 0 ]; do args+=("$1"); shift; done ;;
            *) args+=("$1"); shift ;;
        esac
    done
    # SERVER, DOMAIN_ANCHOR, USE_TCP, QUIET are consumed by the resolver added in a later task
    : "$SERVER" "$DOMAIN_ANCHOR" "$USE_TCP" "$QUIET"

    local verb; verb="${args[0]}"
    if [ -z "$verb" ]; then
        _error "Must provide a verb (find|flatten|check|tree). Run \`$SCRIPT_NAME -h\` for usage"
        return 2
    fi
    local -a rest; rest=("${args[@]:1}")
    case "$verb" in
        find)    _cmd_find    "${rest[@]}" ;;
        flatten) _cmd_flatten "${rest[@]}" ;;
        check)   _cmd_check   "${rest[@]}" ;;
        tree)    _cmd_tree    "${rest[@]}" ;;
        *) _error "Unknown argument '$verb'. Run \`$SCRIPT_NAME -h\` for usage"; return 2 ;;
    esac
)

_spf "$@"
__spf_rc=$?
unset -f _spf
if [ -n "${BASH_SOURCE[0]}" ] && [ "${BASH_SOURCE[0]}" != "$0" ]; then
    eval "unset __spf_rc; return $__spf_rc"
fi
eval "unset __spf_rc; exit $__spf_rc"
