#!/bin/bash
# spf - Resolve and inspect SPF DNS records
#
# Usage:
#   spf [options] find    <domain>           Find matching SPF mechanism for an IP
#   spf [options] flatten <domain>           Print all IPs authorized by an SPF record
#   spf [options] check   <domain>           Check SPF health (lookups, includes, etc.)
#   spf [options] tree    <domain>           Print SPF include tree
#   spf -h
#
# Options:
#   -s, --server <ip>   DNS server to query (default: 8.8.8.8)
#   -d, --domain <dom>  Restrict output to a specific domain anchor
#   --tcp               Force TCP instead of UDP for dig queries
#   -q, --quiet         Suppress informational output
#   -h, --help          Show help message

_spf() (
    local SCRIPT_NAME; SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"
    case "${BASH_SOURCE[0]}" in /dev/*|/proc/*) SCRIPT_NAME="" ;; esac
    case "$SCRIPT_NAME" in ""|bash|sh|zsh|dash) SCRIPT_NAME="spf" ;; esac

    _error() { echo "[ERR][$SCRIPT_NAME] $*" >&2; }
    _warn()  { echo "[WRN][$SCRIPT_NAME] $*" >&2; }

    _show_help() {
        local s; [ -t 1 ] && s=$'\033[4m'
        local r; [ -t 1 ] && r=$'\033[24m'
        echo "NAME"
        echo "  $SCRIPT_NAME - resolve and inspect SPF DNS records"
        echo "SYNOPSIS"
        echo "  $SCRIPT_NAME [${s}options${r}] find    ${s}domain${r}"
        echo "  $SCRIPT_NAME [${s}options${r}] flatten ${s}domain${r}"
        echo "  $SCRIPT_NAME [${s}options${r}] check   ${s}domain${r}"
        echo "  $SCRIPT_NAME [${s}options${r}] tree    ${s}domain${r}"
        echo "  $SCRIPT_NAME -h"
        echo "DESCRIPTION"
        echo "  Fetches and recursively resolves SPF TXT records for a domain."
        echo "  Four subcommands cover the common inspection tasks: find a"
        echo "  matching mechanism for an IP, flatten all authorized addresses,"
        echo "  check record health, and print the full include tree."
        echo "OPTIONS"
        echo "  -s, --server ${s}ip${r}   DNS server to query (default: 8.8.8.8)"
        echo "  -d, --domain ${s}dom${r}  Restrict output to a specific domain anchor"
        echo "  --tcp             Force TCP instead of UDP for dig queries"
        echo "  -q, --quiet       Suppress informational output"
        echo "  -h, --help        Show this help message"
        echo "DEPENDENCIES"
        echo "  dig"
        echo "  python3 (IPv6 matching only)"
        echo "EXIT STATUS"
        echo "  0  Success"
        echo "  1  Runtime failure (network error, dig returned unexpected output)"
        echo "  2  Usage error (missing arg, unknown flag, bad flag value)"
        echo "  3  dig is not installed"
        echo "  4  Negative predicate result (IP did not match any mechanism)"
    }

    _expand_short_opts() {
        # $1 = string of short-opt letters that take a value (e.g. "nXHd"); "" for flag-only scripts
        # $2..$N = "$@"
        # Populates _EXPANDED; caller does: set -- "${_EXPANDED[@]}"; unset _EXPANDED
        local value_opts="$1"; shift
        _EXPANDED=()
        local passthru=""
        local arg
        local rest
        local c
        for arg in "$@"; do
            if [ -n "$passthru" ]; then _EXPANDED+=("$arg"); continue; fi
            case "$arg" in
                --)          passthru=1; _EXPANDED+=("$arg") ;;
                --*|-|"")    _EXPANDED+=("$arg") ;;
                -[a-zA-Z]?*)
                    rest="${arg#-}"
                    while [ -n "$rest" ]; do
                        c="${rest%"${rest#?}"}"; rest="${rest#?}"
                        _EXPANDED+=("-$c")
                        case "$value_opts" in *"$c"*)
                            [ -n "$rest" ] && _EXPANDED+=("$rest")
                            rest="" ;;
                        esac
                    done ;;
                *)           _EXPANDED+=("$arg") ;;
            esac
        done
    }

    # --- resolver engine ---

    _dig_txt() {
        local name; name="$1"
        local tcp; [ "$USE_TCP" ] && tcp="+tcp"
        # join character-strings, drop quotes, keep only the v=spf1 record
        # shellcheck disable=SC2086 # "Double quote to prevent globbing and word splitting." -- $tcp expands to +tcp or empty; the split is intentional
        dig @"$SERVER" $tcp +short TXT "$name" 2>/dev/null \
          | sed 's/" "//g; s/"//g' \
          | grep -i '^v=spf1' \
          | head -n1
    }

    _spf_input() {
        local a; a="$1"
        case "$a" in
            "v=spf1"*) printf '%s\n' "$a" ;;
            -)         local line; IFS= read -r line; printf '%s\n' "$line" ;;
            *)         _dig_txt "$a" ;;
        esac
    }

    # Print one IR row.
    _ir_row() { printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$1" "$2" "$3" "$4" "$5" "$6"; }

    # _emit_host_ips <token> <mech> <src> <depth> <qual>
    _emit_host_ips() {
        local token; token="$1"
        local mech; mech="$2"
        local src; src="$3"
        local depth; depth="$4"
        local qual; qual="$5"
        local host
        case "$token" in
            "$mech")      host="$src" ;;        # bare a / mx -> the current domain
            "$mech":*)    host="${token#"$mech":}"; host="${host%%/*}" ;;
            "$mech"/*)    host="$src" ;;         # a/24 dual-cidr on current domain
        esac
        # cost row for the mechanism itself (1 lookup)
        _ir_row "$depth" "$src" "$qual" "$mech" "$host" 1
        local tcp; [ "$USE_TCP" ] && tcp="+tcp"
        local ip
        # shellcheck disable=SC2086 # "Double quote to prevent globbing and word splitting." -- $tcp expands to +tcp or empty; splitting dig short output on whitespace is intended
        for ip in $(dig @"$SERVER" $tcp +short A "$host" 2>/dev/null); do
            _ir_row "$depth" "$src" "$qual" ip4 "$ip" 0
        done
        # shellcheck disable=SC2086 # "Double quote to prevent globbing and word splitting." -- $tcp expands to +tcp or empty; splitting dig short output on whitespace is intended
        for ip in $(dig @"$SERVER" $tcp +short AAAA "$host" 2>/dev/null); do
            _ir_row "$depth" "$src" "$qual" ip6 "$ip" 0
        done
    }

    # _resolve_rec <record-string> <source_domain> <depth> <ancestor-path>
    _resolve_rec() {
        local record; record="$1"
        local src; src="$2"
        local depth; depth="$3"
        local ancestors; ancestors="$4"
        [ "$QUIET" ] || printf '[INF][%s] %s: %s\n' "$SCRIPT_NAME" "$src" "$record" >&2

        local token
        local qual
        local target
        # strip leading "v=spf1" by splitting the record on spaces (intentional word-split)
        # shellcheck disable=SC2086 # "Double quote to prevent globbing and word splitting." -- splitting an SPF record on whitespace is intended
        set -- $record
        shift   # drop v=spf1
        for token in "$@"; do
            # split qualifier
            qual="+"
            case "$token" in [+~?-]*) qual="${token%%[!+~?-]*}"; token="${token#?}" ;; esac
            case "$token" in
                ip4:*)      _ir_row "$depth" "$src" "$qual" ip4 "${token#ip4:}" 0 ;;
                ip6:*)      _ir_row "$depth" "$src" "$qual" ip6 "${token#ip6:}" 0 ;;
                all)        _ir_row "$depth" "$src" "$qual" all "" 0 ;;
                include:*)  target="${token#include:}"
                            _ir_row "$depth" "$src" "$qual" include "$target" 1
                            _walk_into "$target" "$depth" "$ancestors" ;;
                redirect=*) target="${token#redirect=}"
                            _ir_row "$depth" "$src" "$qual" redirect "$target" 1
                            _walk_into "$target" "$depth" "$ancestors" ;;
                a|a:*|a/*)      _emit_host_ips "$token" a  "$src" "$depth" "$qual" ;;
                mx|mx:*|mx/*)   _emit_host_ips "$token" mx "$src" "$depth" "$qual" ;;
                exists:*)   _ir_row "$depth" "$src" "$qual" exists "${token#exists:}" 1 ;;
                ptr)        _ir_row "$depth" "$src" "$qual" ptr "" 1 ;;
                ptr:*)      _ir_row "$depth" "$src" "$qual" ptr "${token#ptr:}" 1 ;;
                v=spf1)     ;;   # already shifted, but be safe
                *)          ;;   # unknown token: ignore (verify's job, not ours)
            esac
        done
    }

    # follow include/redirect with cycle + cap guards
    _walk_into() {
        local target; target="$1"
        local parent_depth; parent_depth="$2"
        local ancestors; ancestors="$3"
        case " $ancestors " in *" $target "*) return 0 ;; esac   # cycle: skip
        if [ "$parent_depth" -ge 20 ]; then return 0; fi          # depth cap
        local sub; sub="$(_dig_txt "$target")"
        [ "$sub" ] || { [ "$QUIET" ] || printf '[WRN][%s] no SPF record for %s\n' "$SCRIPT_NAME" "$target" >&2; return 0; }
        _resolve_rec "$sub" "$target" "$((parent_depth + 1))" "$ancestors $target"
    }

    _resolve() {
        local arg; arg="$1"
        local anchor; anchor="${2:-$DOMAIN_ANCHOR}"
        local root; root="$(_spf_input "$arg")"
        if [ -z "$root" ]; then
            _error "No SPF record found for $arg"
            return 1
        fi
        local rootsrc; rootsrc="$arg"
        case "$arg" in "v=spf1"*|-) rootsrc="${anchor:-<record>}" ;; esac
        _resolve_rec "$root" "$rootsrc" 0 "$rootsrc"
    }

    # --- IPv4 CIDR helpers ---

    _ip4_to_int() {
        local IFS=.
        # shellcheck disable=SC2086 # "Double quote to prevent globbing and word splitting." -- intentional split of dotted-quad on '.'
        set -- $1
        [ $# -eq 4 ] || return 2
        local o
        for o in "$@"; do
            case "$o" in ''|*[!0-9]*) return 2 ;; esac
            [ "$o" -le 255 ] || return 2
        done
        printf '%s\n' "$(( ($1 << 24) | ($2 << 16) | ($3 << 8) | $4 ))"
    }

    _ip4_in_cidr() {
        local ip; ip="$1"
        local cidr; cidr="$2"
        local net; net="${cidr%/*}"
        local prefix
        case "$cidr" in */*) prefix="${cidr#*/}" ;; *) prefix=32 ;; esac
        case "$prefix" in ''|*[!0-9]*) return 2 ;; esac
        [ "$prefix" -le 32 ] || return 2

        local ipi; ipi="$(_ip4_to_int "$ip")" || return 2
        local neti; neti="$(_ip4_to_int "$net")" || return 2

        local mask
        if [ "$prefix" -eq 0 ]; then
            mask=0
        else
            mask=$(( (0xFFFFFFFF << (32 - prefix)) & 0xFFFFFFFF ))
        fi
        [ $(( ipi & mask )) -eq $(( neti & mask )) ]
    }

    # --- command stubs (implemented in later tasks) ---

    _cmd_find() {
        local input; input=""
        local ip; ip=""
        local arg
        for arg in "$@"; do
            case "$arg" in
                -*) ;;   # global opts already consumed; ignore strays
                *)  if [ -z "$input" ]; then input="$arg"; else ip="$arg"; fi ;;
            esac
        done
        if [ -z "$input" ]; then
            _error "Must provide a domain or record. Run \`$SCRIPT_NAME -h\` for usage"
            return 2
        fi
        if [ -z "$ip" ]; then
            _error "ip is required. Run \`$SCRIPT_NAME -h\` for usage"
            return 2
        fi

        local ir; ir="$(_resolve "$input")" || return 1

        # Walk rows in order; first containing CIDR wins. (IPv4 query path.)
        local depth
        local src
        local qual
        local mech
        local val
        local cost
        # shellcheck disable=SC2034 # cost is read from the IR to keep field alignment but not used in this consumer
        while IFS=$'\t' read -r depth src qual mech val cost; do
            case "$mech" in
                ip4)
                    if _ip4_in_cidr "$ip" "$val"; then
                        printf '%s %s (qualifier: %s)\n' "$ip is listed/covered by" "$src" "$qual"
                        printf '  matched: %s:%s\n' "$mech" "$val"
                        return 0
                    fi ;;
            esac
        done <<EOF
$ir
EOF

        printf '%s\n' "$ip not found in $input's SPF record"
        return 4
    }
    _cmd_check() { return 0; }
    _cmd_tree()  { return 0; }

    _chunk_record() {
        local full; full="$1"
        local out; out=""
        local cur; cur=""
        local tok
        # shellcheck disable=SC2086 # "Double quote to prevent globbing and word splitting." -- splitting record tokens on whitespace is intended
        for tok in $full; do
            if [ -z "$cur" ]; then
                cur="$tok"
            elif [ $(( ${#cur} + ${#tok} + 1 )) -le 255 ]; then
                cur="$cur $tok"
            else
                out="$out \"$cur\""
                cur="$tok"
            fi
        done
        [ "$cur" ] && out="$out \"$cur\""
        printf '%s\n' "${out# }"
    }

    _cmd_flatten() {
        local record_mode; record_mode=""
        local input; input=""
        local arg
        for arg in "$@"; do
            case "$arg" in
                --record) record_mode=1 ;;
                *) input="$arg" ;;
            esac
        done
        if [ -z "$input" ]; then
            _error "Must provide a domain or record. Run \`$SCRIPT_NAME -h\` for usage"
            return 2
        fi

        local ir; ir="$(_resolve "$input")" || return 1

        # note unevaluable mechanisms
        local exists_n; exists_n="$(printf '%s\n' "$ir" | awk -F'\t' '$4=="exists"' | grep -c .)"
        local ptr_n;    ptr_n="$(printf '%s\n' "$ir" | awk -F'\t' '$4=="ptr"' | grep -c .)"
        [ "$exists_n" -gt 0 ] && _warn "cannot statically evaluate exists ($exists_n occurrence(s))"
        [ "$ptr_n" -gt 0 ]    && _warn "cannot statically evaluate ptr ($ptr_n occurrence(s))"

        # collect addresses: ip4 then ip6, each sorted+deduped
        local v4; v4="$(printf '%s\n' "$ir" | awk -F'\t' '$4=="ip4"{print $5}' | sort -u -t. -k1,1n -k2,2n -k3,3n -k4,4n)"
        local v6; v6="$(printf '%s\n' "$ir" | awk -F'\t' '$4=="ip6"{print $5}' | sort -u)"

        if [ -z "$record_mode" ]; then
            [ "$v4" ] && printf '%s\n' "$v4"
            [ "$v6" ] && printf '%s\n' "$v6"
            return 0
        fi

        # --record: build mechanisms, find the root all qualifier, chunk <=255 bytes
        local allq; allq="$(printf '%s\n' "$ir" | awk -F'\t' '$1=="0" && $4=="all"{print $3; exit}')"
        local all_mech; all_mech="${allq:-~}all"
        local mechs; mechs=""
        local ip
        # shellcheck disable=SC2086 # "Double quote to prevent globbing and word splitting." -- splitting the newline/space-separated address list is intended
        for ip in $v4; do mechs="$mechs ip4:$ip"; done
        # shellcheck disable=SC2086 # "Double quote to prevent globbing and word splitting." -- splitting the newline/space-separated address list is intended
        for ip in $v6; do mechs="$mechs ip6:$ip"; done
        _chunk_record "v=spf1$mechs $all_mech"
    }

    # --- defaults and parse arguments ---
    local SERVER; SERVER="8.8.8.8"
    local DOMAIN_ANCHOR; DOMAIN_ANCHOR=""
    local USE_TCP; USE_TCP=""
    local QUIET; QUIET=""
    local -a args=()

    _expand_short_opts "sd" "$@"
    set -- "${_EXPANDED[@]}"; unset _EXPANDED

    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help) _show_help; return 0 ;;
            -s|--server)
                [ -n "${2-}" ] || { _error "--server requires a value. Run \`$SCRIPT_NAME -h\` for usage"; return 2; }
                SERVER="$2"; shift 2 ;;
            --server=*)
                SERVER="${1#*=}"
                [ -n "$SERVER" ] || { _error "--server requires a value. Run \`$SCRIPT_NAME -h\` for usage"; return 2; }
                shift ;;
            -d|--domain)
                [ -n "${2-}" ] || { _error "--domain requires a value. Run \`$SCRIPT_NAME -h\` for usage"; return 2; }
                DOMAIN_ANCHOR="$2"; shift 2 ;;
            --domain=*)
                DOMAIN_ANCHOR="${1#*=}"
                [ -n "$DOMAIN_ANCHOR" ] || { _error "--domain requires a value. Run \`$SCRIPT_NAME -h\` for usage"; return 2; }
                shift ;;
            --tcp) USE_TCP=1; shift ;;
            -q|--quiet) QUIET=1; shift ;;
            --) shift; while [ $# -gt 0 ]; do args+=("$1"); shift; done ;;
            *) args+=("$1"); shift ;;
        esac
    done
    local verb; verb="${args[0]}"
    if [ -z "$verb" ]; then
        _error "Must provide a verb (find|flatten|check|tree). Run \`$SCRIPT_NAME -h\` for usage"
        return 2
    fi
    local -a rest; rest=("${args[@]:1}")
    case "$verb" in
        find)    _cmd_find    "${rest[@]}" ;;
        flatten) _cmd_flatten "${rest[@]}" ;;
        check)   _cmd_check   "${rest[@]}" ;;
        tree)    _cmd_tree    "${rest[@]}" ;;
        # __ir: test-only -- dumps the raw IR for the test harness
        __ir)    _resolve     "${rest[@]}" ;;
        # __ip4: test-only -- exercises _ip4_in_cidr directly
        __ip4)   _ip4_in_cidr "${rest[@]}"; return $? ;;
        *) _error "Unknown argument '$verb'. Run \`$SCRIPT_NAME -h\` for usage"; return 2 ;;
    esac
)

_spf "$@"
__spf_rc=$?
unset -f _spf
if [ -n "${BASH_SOURCE[0]}" ] && [ "${BASH_SOURCE[0]}" != "$0" ]; then
    eval "unset __spf_rc; return $__spf_rc"
fi
eval "unset __spf_rc; exit $__spf_rc"
